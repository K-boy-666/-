<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>暗黑骑士：深渊重临 - 1.9 巅峰架构版</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&display=swap');
        
        :root { --bg-dark: #0a0a0c; --soul-color: #a78bfa; --hp-color: #ef4444; --block-color: #3b82f6; }
        body { background-color: var(--bg-dark); color: #e2e8f0; font-family: 'Noto Serif SC', serif; overflow: hidden; user-select: none; }

        @keyframes floatUp { 0% { transform: translateY(0) scale(1); opacity: 1; } 100% { transform: translateY(-60px) scale(1.3); opacity: 0; } }
        .floating-text { animation: floatUp 0.8s ease-out forwards; position: absolute; z-index: 9999; font-weight: 900; text-shadow: 0px 2px 4px rgba(0,0,0,0.8); pointer-events: none; }
        @keyframes shake { 10%, 90% { transform: translate3d(-2px, 0, 0); } 20%, 80% { transform: translate3d(4px, 0, 0); } 30%, 50%, 70% { transform: translate3d(-6px, 0, 0); } 40%, 60% { transform: translate3d(6px, 0, 0); } }
        .shake { animation: shake 0.3s cubic-bezier(.36,.07,.19,.97) both; }
        .enemy-shake { animation: shake 0.2s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes damageFlash { 0% { filter: brightness(1) sepia(0) hue-rotate(0) saturate(1); } 50% { filter: brightness(1.5) sepia(1) hue-rotate(-50deg) saturate(5); } 100% { filter: brightness(1) sepia(0) hue-rotate(0) saturate(1); } }
        .damage-flash { animation: damageFlash 0.2s; }

        /* 攻击斩击动画 */
        .slash-fx { position: absolute; width: 150px; height: 4px; background: linear-gradient(90deg, transparent, #fff, #ef4444, #7f1d1d, transparent); border-radius: 50%; filter: drop-shadow(0 0 5px #ef4444); transform-origin: center; animation: slashAnim 0.25s cubic-bezier(0.1, 0.9, 0.2, 1) forwards; pointer-events: none; z-index: 1000; }
        @keyframes slashAnim { 0% { transform: translate(-50%, -50%) rotate(-45deg) scaleX(0); opacity: 1; } 50% { transform: translate(-50%, -50%) rotate(-45deg) scaleX(1.5); opacity: 1; } 100% { transform: translate(-50%, -50%) rotate(-45deg) scaleX(0.5); opacity: 0; } }

        .hand-wrapper { display: flex; justify-content: center; align-items: flex-end; position: relative; width: 100%; height: 220px; }
        .card { transition: all 0.2s ease-out; cursor: pointer; width: 130px; height: 180px; border: 2px solid #334155; background: linear-gradient(135deg, #1e293b, #0f172a); position: relative; margin-left: -40px; flex-shrink: 0; border-radius: 8px; }
        .card.card-grid-item { margin-left: 0; transform: none !important; }
        .card.card-grid-item:hover { transform: translateY(-10px) !important; border-color: #fbbf24; box-shadow: 0 10px 20px rgba(0, 0, 0, 0.8); }
        .card:first-child { margin-left: 0; }
        .card:hover { transform: translateY(-40px) scale(1.15) rotate(0deg) !important; z-index: 100 !important; border-color: #fbbf24; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.8); }
        .card.affordable { border-color: #6366f1; }
        .card.unaffordable { opacity: 0.6; cursor: not-allowed; filter: grayscale(0.8); }
        .card.preview-card { margin-left: 0; transform: scale(1.2) !important; cursor: default; }

        /* Slay the Spire Map Styles */
        .map-grid { display: flex; flex-direction: column-reverse; gap: 30px; padding: 60px 20px; position: relative; max-width: 500px; margin: 0 auto; }
        .map-row { display: grid; grid-template-columns: repeat(5, 1fr); justify-items: center; align-items: center; width: 100%; z-index: 10; position: relative; height: 50px; }
        .map-node-wrapper { width: 50px; height: 50px; display: flex; justify-content: center; align-items: center; }
        .node { width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: not-allowed; opacity: 0.4; border: 2px solid #444; transition: all 0.3s; background: #18181b; }
        .node.reachable { cursor: pointer; opacity: 1; border-color: #fbbf24; box-shadow: 0 0 15px rgba(251, 191, 36, 0.5); background: #27272a; }
        .node.reachable:hover { background: #3f3f46; transform: scale(1.2); }
        .node.visited { opacity: 0.3; background: #000; border-color: #555; }
        .node.current { border-color: #fff; box-shadow: 0 0 20px #fff; opacity: 1; transform: scale(1.2); z-index: 10; background: #3f3f46; }

        .vignette { pointer-events: none; position: fixed; inset: 0; background: radial-gradient(circle, transparent 50%, rgba(0,0,0,0.8) 100%); z-index: 90; }
        @keyframes soul-glow { 0% { box-shadow: 0 0 5px var(--soul-color); } 50% { box-shadow: 0 0 15px var(--soul-color); } 100% { box-shadow: 0 0 5px var(--soul-color); } }
        .soul-badge { animation: soul-glow 2s infinite; }

        /* 遗物悬停样式修复 */
        .relic-container { position: relative; z-index: 10; }
        .relic-container:hover { z-index: 50; }
        .relic-tooltip { 
            visibility: hidden; opacity: 0; transition: opacity 0.2s; 
            position: absolute; top: 130%; left: 50%; transform: translateX(-50%); 
            width: max-content; max-width: 240px; background: #18181b; border: 1px solid #52525b; 
            padding: 10px; border-radius: 6px; z-index: 9999; text-align: left; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.9); pointer-events: none;
        }
        .relic-container:hover .relic-tooltip { visibility: visible; opacity: 1; }
        .intent-tooltip { bottom: auto; top: 120%; }
        
        .event-btn { background: #18181b; border: 1px solid #3f3f46; padding: 16px; border-radius: 8px; text-align: left; font-weight: bold; color: #d4d4d8; transition: all 0.2s; cursor: pointer; display: flex; align-items: center; gap: 10px; }
        .event-btn:hover { background: #27272a; border-color: #a78bfa; transform: translateX(5px); }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #18181b; }
        ::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #52525b; }

        /* 发光边框特效 */
        .glow-border { animation: borderGlow 2s infinite; }
        @keyframes borderGlow {
            0% { box-shadow: 0 0 5px #8b5cf6, inset 0 0 5px #8b5cf6; border-color: #8b5cf6; }
            50% { box-shadow: 0 0 20px #8b5cf6, inset 0 0 10px #8b5cf6; border-color: #a78bfa; }
            100% { box-shadow: 0 0 5px #8b5cf6, inset 0 0 5px #8b5cf6; border-color: #8b5cf6; }
        }
    </style>
</head>
<body class="h-screen w-screen flex items-center justify-center p-2">

    <!-- 隐藏的本地音频播放器 -->
    <audio id="custom-bgm" loop></audio>

    <div id="game-app" class="relative w-full h-full max-w-6xl bg-zinc-900 rounded-xl border border-zinc-800 shadow-2xl overflow-hidden flex flex-col z-0">
        
        <!-- 顶栏重构版 -->
        <div class="flex justify-between items-start p-3 bg-zinc-950 border-b border-zinc-800 z-[60] hidden w-full" id="top-bar">
            <!-- 左侧状态 -->
            <div class="flex flex-col gap-2 shrink-0 w-48">
                <div class="flex items-center gap-2" id="player-hp-ui">
                    <span class="text-red-500 font-bold text-sm">HP</span>
                    <div class="w-full h-4 bg-zinc-800 rounded-full overflow-hidden border border-zinc-700 relative">
                        <div id="hp-bar" class="h-full bg-red-600 transition-all duration-300" style="width: 100%;"></div>
                        <span id="hp-text" class="absolute inset-0 flex justify-center items-center text-[10px] font-bold drop-shadow-md">80/80</span>
                    </div>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-yellow-500 font-bold text-sm">GOLD</span>
                    <span id="gold-text" class="text-yellow-200 font-bold">99</span>
                </div>
            </div>
            
            <!-- 中间遗物展示区 -->
            <div class="flex gap-2 flex-wrap flex-1 px-8 justify-center items-start content-start" id="relics">
                <!-- 动态生成 -->
            </div>

            <!-- 右侧楼层 -->
            <div class="flex flex-col items-end gap-2 shrink-0 w-32">
                <span id="floor-display" class="text-zinc-500 text-sm italic font-bold">第 1 层</span>
                <button onclick="viewMap()" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 px-3 py-1 rounded text-xs transition-colors text-white font-bold shadow-lg">查看地图</button>
            </div>
        </div>

        <!-- 主屏幕内容 -->
        <div class="flex-grow relative overflow-hidden flex flex-col z-10">
            
            <!-- 场景0: 开局遗物选择与BGM设置 -->
            <div id="start-view" class="hidden flex-grow flex flex-col items-center justify-center bg-zinc-950 p-12 z-50">
                <h1 class="text-5xl font-black text-violet-500 mb-2 tracking-widest drop-shadow-[0_0_15px_rgba(139,92,246,0.5)]">暗黑骑士：深渊重临</h1>
                <p class="text-zinc-500 mb-8 italic">The Dark Knight: Abyss Returns</p>
                
                <!-- BGM 上传区 -->
                <div class="mb-12 flex flex-col items-center">
                    <label for="bgm-upload" id="bgm-label" class="cursor-pointer bg-zinc-800 hover:bg-zinc-700 text-zinc-300 px-6 py-3 rounded-lg border border-zinc-600 font-bold transition-all hover:scale-105 shadow-lg">
                        🎵 载入本地背景音乐 (可选)
                    </label>
                    <input type="file" id="bgm-upload" accept="audio/*" class="hidden" onchange="loadCustomBGM(event)">
                </div>

                <h2 class="text-2xl font-bold text-zinc-300 mb-6">神祇赐予了你一个额外的恩赐...</h2>
                <div id="start-relics" class="flex gap-8 flex-wrap justify-center"></div>
            </div>

            <!-- 场景1: 战斗 -->
            <div id="combat-view" class="hidden flex-grow flex flex-col p-6 items-center justify-between">
                <div class="w-full flex justify-around items-end pt-12">
                    <div class="flex flex-col items-center gap-4 relative" id="player-avatar-container">
                        <div class="absolute -top-12 soul-badge bg-violet-600 text-white px-4 py-1 rounded-full text-xs font-bold z-20">
                            ✨ <span id="soul-val">0</span> 灵魂
                        </div>
                        <div id="player-block" class="absolute -right-2 top-0 bg-blue-600 text-white w-8 h-8 rounded flex items-center justify-center font-bold border border-white hidden z-10">0</div>
                        <div class="w-20 h-28 bg-zinc-700 rounded-lg border-2 border-zinc-500 flex items-center justify-center text-4xl shadow-xl relative z-0">👤</div>
                        <!-- Player Buffs -->
                        <div id="player-buffs-ui" class="absolute -bottom-6 flex gap-1 w-full justify-center"></div>
                    </div>
                    <div id="enemies" class="flex gap-12"></div>
                </div>
                <div id="battle-log" class="absolute left-6 top-6 w-56 text-[11px] text-zinc-500 pointer-events-none flex flex-col-reverse gap-1 opacity-60"></div>
            </div>

            <!-- 场景2: 事件 -->
            <div id="event-view" class="hidden flex-grow flex items-center justify-center bg-zinc-950/40 p-12">
                <div class="max-w-2xl w-full bg-zinc-900 border border-zinc-800 p-8 rounded-lg shadow-2xl text-center">
                    <h2 id="event-title" class="text-3xl font-bold text-violet-400 mb-4 border-b border-zinc-800 pb-4">发生事件</h2>
                    <p id="event-desc" class="text-zinc-300 italic mb-8 text-lg leading-relaxed text-left"></p>
                    <div id="event-options" class="flex flex-col gap-3"></div>
                </div>
            </div>

            <!-- 场景3: 休息处 -->
            <div id="rest-view" class="hidden flex-grow flex flex-col items-center justify-center p-12">
                <div id="rest-menu" class="text-center w-full max-w-4xl">
                    <h2 class="text-3xl font-bold text-orange-400 mb-8">休息处 - 篝火</h2>
                    <div class="flex justify-center gap-6">
                        <button onclick="handleRest('heal')" class="w-48 h-64 bg-zinc-800 hover:bg-zinc-700 border-2 border-zinc-700 rounded-xl flex flex-col items-center justify-center gap-4 transition-all hover:-translate-y-2 shadow-xl">
                            <span class="text-6xl">💤</span><span class="font-bold text-xl text-white">休息</span><span class="text-sm text-green-500 px-4">回复 30% 生命值</span>
                        </button>
                        <button onclick="handleRest('smith')" class="w-48 h-64 bg-zinc-800 hover:bg-zinc-700 border-2 border-zinc-700 rounded-xl flex flex-col items-center justify-center gap-4 transition-all hover:-translate-y-2 shadow-xl">
                            <span class="text-6xl">🔨</span><span class="font-bold text-xl text-white">锻造</span><span class="text-sm text-blue-400 px-4">升级一张卡牌</span>
                        </button>
                        <!-- ✨ 深渊铸卡 ✨ -->
                        <button onclick="handleRest('forge')" class="w-48 h-64 bg-zinc-900 hover:bg-zinc-800 border-2 border-violet-700 rounded-xl flex flex-col items-center justify-center gap-4 transition-all hover:-translate-y-2 shadow-[0_0_15px_rgba(139,92,246,0.2)] hover:shadow-[0_0_20px_rgba(139,92,246,0.6)] glow-border relative overflow-hidden group">
                            <div class="absolute inset-0 bg-violet-600/10 group-hover:bg-violet-600/20 transition-colors"></div>
                            <span class="text-6xl relative z-10">✨</span>
                            <span class="font-bold text-xl text-violet-300 relative z-10">深渊铸造</span>
                            <span class="text-xs text-violet-400 px-4 relative z-10">利用大语言模型创造新卡</span>
                        </button>
                    </div>
                </div>
                
                <div id="smith-menu" class="hidden flex flex-col w-full h-full">
                    <h2 class="text-2xl font-bold text-blue-400 mb-4 text-center">选择一张卡牌进行升级</h2>
                    <div id="smith-cards" class="flex-grow overflow-y-auto flex flex-wrap justify-center gap-4 p-4 border border-zinc-800 rounded bg-zinc-950"></div>
                    <button onclick="cancelRestSubmenu()" class="mt-4 mx-auto bg-zinc-800 hover:bg-zinc-700 px-6 py-2 rounded text-zinc-300">取消</button>
                </div>

                <div id="forge-menu" class="hidden flex flex-col items-center justify-center w-full h-full max-w-2xl mx-auto">
                    <div class="bg-zinc-900 p-8 rounded-xl border border-violet-800/50 shadow-[0_0_30px_rgba(139,92,246,0.15)] w-full text-center">
                        <h2 class="text-3xl font-black text-violet-400 mb-4 tracking-wider">✨ 深渊铸卡</h2>
                        <p class="text-zinc-400 mb-8">向深渊诉说你的渴望，利用源初的混沌为你具象化一张独属卡牌。</p>
                        
                        <input type="text" id="forge-input" placeholder="例如：牺牲血量对全体造成爆炸伤害..." 
                               class="w-full bg-zinc-950 border-2 border-zinc-700 rounded-lg p-4 text-white text-lg mb-8 focus:border-violet-500 focus:ring focus:ring-violet-500/20 focus:outline-none transition-all placeholder:text-zinc-600">
                        
                        <div class="flex justify-center gap-6">
                            <button onclick="cancelRestSubmenu()" class="bg-zinc-800 hover:bg-zinc-700 px-8 py-3 rounded-lg text-white font-bold transition-colors">取消</button>
                            <button id="forge-btn" onclick="executeForge()" class="bg-violet-700 hover:bg-violet-600 px-8 py-3 rounded-lg text-white font-bold transition-all shadow-[0_0_15px_rgba(139,92,246,0.4)] flex items-center gap-2">
                                <span>✨</span> 开始铸造
                            </button>
                        </div>
                        
                        <div id="forge-status" class="mt-8 text-violet-400 font-bold animate-pulse hidden">
                            ✨ 深渊正在聆听你的渴望，编织命运的丝线...
                        </div>
                    </div>
                </div>
            </div>

            <!-- 场景4: 商店 -->
            <div id="shop-view" class="hidden flex-grow flex flex-col items-center p-8 bg-zinc-950 overflow-y-auto">
                <h2 class="text-3xl font-bold text-yellow-500 mb-6 flex items-center gap-2">💰 诡秘商人 <span class="text-sm text-zinc-400 font-normal">"有钱能使鬼推磨..."</span></h2>
                <div class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                    <div class="bg-zinc-900 border border-zinc-800 p-4 rounded-xl">
                        <h3 class="text-zinc-400 mb-4 text-center font-bold">卡牌出售</h3>
                        <div id="shop-cards" class="flex justify-center gap-4 flex-wrap"></div>
                    </div>
                    <div class="bg-zinc-900 border border-zinc-800 p-4 rounded-xl flex flex-col items-center">
                        <h3 class="text-zinc-400 mb-4 text-center font-bold">遗物与服务</h3>
                        <div id="shop-relics" class="flex justify-center gap-4 mb-6"></div>
                        <button onclick="buyRemoval()" class="bg-red-900/50 hover:bg-red-800/80 border border-red-700 p-3 rounded-lg flex flex-col items-center gap-1 w-48 transition-colors">
                            <span class="text-2xl">🔥</span><span class="font-bold text-white">移除卡牌服务</span><span id="remove-price" class="text-yellow-400 text-sm">75 金币</span>
                        </button>
                    </div>
                </div>
                <button onclick="endRoom()" class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 px-10 py-3 rounded-lg font-bold text-lg text-white">离开商店</button>
            </div>

            <!-- 场景5: 战斗奖励结算 -->
            <div id="reward-view" class="hidden flex-grow flex flex-col items-center justify-center p-12 bg-black/80">
                <div class="bg-zinc-900 border border-zinc-700 p-8 rounded-xl max-w-md w-full text-center shadow-2xl">
                    <h2 class="text-3xl font-bold text-yellow-500 mb-6 border-b border-zinc-700 pb-2">战斗胜利</h2>
                    <div id="reward-list" class="flex flex-col gap-3 mb-6"></div>
                    <button onclick="endRoom()" class="bg-zinc-800 hover:bg-zinc-700 px-6 py-2 rounded text-zinc-300 w-full font-bold transition-colors">继续前进</button>
                </div>
            </div>

            <!-- 场景6: 地图选择 -->
            <div id="map-view" class="hidden flex-grow overflow-y-auto bg-zinc-950 p-4 flex flex-col items-center relative">
                <div class="text-center mb-4 z-20 flex flex-col items-center">
                    <h1 class="text-2xl font-bold text-zinc-400 tracking-widest uppercase mb-2">幽暗森林</h1>
                    <span class="text-xs text-zinc-500 bg-zinc-800 px-3 py-1 rounded-full border border-zinc-700 shadow-md">在纠结的网状小径中规划你的路线</span>
                </div>
                <button id="return-room-btn" onclick="returnToActiveRoom()" class="hidden sticky top-4 z-50 bg-blue-900 hover:bg-blue-800 text-white border border-blue-500 px-6 py-2 rounded-full font-bold shadow-lg mb-4">返回当前房间</button>
                <div id="map-container" class="map-grid w-full max-w-3xl flex-grow mx-auto relative">
                    <svg id="map-lines" class="absolute inset-0 w-full h-full pointer-events-none z-0"></svg>
                </div>
            </div>
        </div>

        <!-- 底部交互 (手牌) -->
        <div id="player-controls" class="hidden h-60 bg-zinc-950/90 border-t border-zinc-800 relative z-20">
            <div class="absolute -top-6 left-1/2 -translate-x-1/2 bg-zinc-900 border-2 border-zinc-600 w-16 h-16 rounded-full flex items-center justify-center text-xl font-bold text-indigo-400 z-50 shadow-[0_0_15px_rgba(79,70,229,0.5)]">
                <span id="energy-now">3</span>/<span id="energy-max">3</span>
            </div>
            <div class="absolute left-8 bottom-8 text-[10px] text-zinc-500">
                <div>抽牌堆: <span id="draw-count">0</span></div>
                <div>弃牌堆: <span id="discard-count">0</span></div>
            </div>
            <div id="hand-display" class="hand-wrapper"></div>
            <button onclick="executeEndTurn()" class="absolute right-8 top-1/2 -translate-y-1/2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 px-8 py-4 rounded font-bold text-sm text-white transition-colors">结束回合</button>
        </div>

        <div class="vignette"></div>
    </div>

    <!-- 弹窗/遮罩 -->
    <div id="modal" class="fixed inset-0 bg-black/90 z-[100] hidden flex flex-col items-center justify-center p-8">
        <div id="modal-content" class="bg-zinc-900 border border-zinc-700 p-8 rounded-xl max-w-4xl w-full text-center shadow-2xl relative"></div>
        <button id="modal-close-btn" onclick="closeModal()" class="hidden mt-6 bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 px-6 py-2 rounded text-white font-bold">取消 / 关闭</button>
    </div>

    <script>
        // --- 核心配置 ---
        const apiKey = ""; // Gemini API Key 注入
        const PLAYER_INITIAL_HP = 80;
        const INITIAL_DECK = ['strike', 'strike', 'strike', 'defend', 'defend', 'defend', 'defend', 'weeping_slash', 'soul_bite', 'soul_rend'];

        // --- 本地背景音乐加载器 (修复自动播放问题) ---
        function loadCustomBGM(event) {
            const file = event.target.files[0];
            if (file) {
                const url = URL.createObjectURL(file);
                const audio = document.getElementById('custom-bgm');
                audio.src = url;
                audio.volume = 0.3;
                
                const label = document.getElementById('bgm-label');
                label.innerText = '⏳ 正在加载音频...';
                
                // 监听 canplay 事件，确保流加载完成后再播放，防止被浏览器策略阻断
                audio.oncanplay = () => {
                    audio.play().then(() => {
                        label.innerText = '🎵 播放中: ' + file.name.substring(0, 20) + '...';
                        label.classList.replace('text-zinc-300', 'text-green-400');
                        label.classList.add('border-green-600');
                    }).catch(e => {
                        console.log("Play failed, need interaction:", e);
                        label.innerText = '⚠️ 点击这里以允许播放 BGM';
                        label.classList.replace('text-green-400', 'text-yellow-400');
                        label.onclick = () => { audio.play(); label.innerText = '🎵 播放中!'; label.onclick = null; };
                    });
                };
                audio.load();
            }
        }

        // --- 音效引擎 (保留短促SFX) ---
        let audioCtx = null;
        function initAudio() { if (!audioCtx) { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } if (audioCtx.state === 'suspended') audioCtx.resume(); }
        document.addEventListener('click', initAudio, { once: true });
        
        function playSound(type) {
            if (!audioCtx || audioCtx.state !== 'running') return;
            const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain(); 
            const now = audioCtx.currentTime;
            
            if (type === 'hit') { 
                osc.type = 'square'; osc.frequency.setValueAtTime(800, now); osc.frequency.exponentialRampToValueAtTime(100, now + 0.1); 
                const filter = audioCtx.createBiquadFilter(); filter.type = 'highpass'; filter.frequency.value = 1500;
                osc.connect(filter); filter.connect(gain); gain.connect(audioCtx.destination);
                gain.gain.setValueAtTime(0.4, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.15); 
                osc.start(now); osc.stop(now + 0.15); 
            } 
            else if (type === 'block') { 
                osc.type = 'square'; osc.connect(gain); gain.connect(audioCtx.destination);
                osc.frequency.setValueAtTime(300, now); gain.gain.setValueAtTime(0.1, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.15); osc.start(now); osc.stop(now + 0.15); 
            } 
            else if (type === 'heal') { 
                osc.type = 'sine'; osc.connect(gain); gain.connect(audioCtx.destination);
                osc.frequency.setValueAtTime(400, now); osc.frequency.linearRampToValueAtTime(800, now + 0.2); gain.gain.setValueAtTime(0.1, now); gain.gain.linearRampToValueAtTime(0.01, now + 0.2); osc.start(now); osc.stop(now + 0.2); 
            } 
            else if (type === 'error') { 
                osc.type = 'sawtooth'; osc.connect(gain); gain.connect(audioCtx.destination);
                osc.frequency.setValueAtTime(100, now); osc.frequency.linearRampToValueAtTime(80, now + 0.15); gain.gain.setValueAtTime(0.2, now); gain.gain.linearRampToValueAtTime(0.01, now + 0.15); osc.start(now); osc.stop(now + 0.15); 
            } 
            else if (type === 'card') { 
                osc.type = 'sine'; osc.connect(gain); gain.connect(audioCtx.destination);
                osc.frequency.setValueAtTime(600, now); gain.gain.setValueAtTime(0.05, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.05); osc.start(now); osc.stop(now + 0.05); 
            }
        }

