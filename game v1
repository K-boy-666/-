                const relic = RELICS_DB[rKey];
                const el = document.createElement('div');
                el.className = "flex flex-col items-center gap-4 bg-zinc-900 border border-zinc-700 p-6 rounded-xl cursor-pointer hover:border-violet-500 hover:scale-105 transition-all w-64 text-center shadow-xl relative z-10";
                el.innerHTML = `
                    <div class="text-6xl filter drop-shadow-lg mb-2">${relic.icon}</div>
                    <div class="text-xl font-bold text-yellow-500">${relic.name}</div>
                    <div class="text-sm text-zinc-400 h-16">${relic.desc}</div>
                    <div class="mt-4 text-xs font-bold text-violet-400 bg-zinc-800 px-3 py-1 rounded">点击获取</div>
                `;
                el.onclick = () => {
                    game.relics.push(rKey); 
                    initAudio(); 
                    playSound('block');
                    document.getElementById('top-bar').classList.remove('hidden');
                    generateMap(); endRoom(); 
                };
                container.appendChild(el);
            });
        }

        // --- 杀戮尖塔同款：分层树状地图生成算法 ---
        function generateMap() {
            game.map = Array(15).fill(null).map(() => Array(5).fill(null));
            
            // 0层 (起始层) 分配 5 个战斗节点
            for (let i = 0; i < 5; i++) {
                game.map[0][i] = { id: `0-${i}`, type: 'combat', visited: false, children: [] };
            }

            // 1-13层 生成向上的无交叉路径
            for (let i = 0; i < 13; i++) {
                let min_k = 0;
                for (let j = 0; j < 5; j++) {
                    if (game.map[i][j] !== null) {
                        let possible = [j-1, j, j+1].filter(x => x >= 0 && x < 5 && x >= min_k);
                        if (possible.length === 0) {
                            possible = [Math.max(min_k, j)];
                            if (possible[0] >= 5) possible = [4];
                        }
                        
                        let numConnections = (Math.random() < 0.3 && possible.length > 1) ? 2 : 1;
                        possible.sort(() => 0.5 - Math.random());
                        let picked = possible.slice(0, numConnections).sort((a,b) => a-b);
                        
                        min_k = Math.max(min_k, picked[picked.length - 1] || 0);

                        for (let k of picked) {
                            if (!game.map[i+1][k]) {
                                game.map[i+1][k] = { id: `${i+1}-${k}`, type: getRandomNodeType(i + 1), visited: false, children: [] };
                            }
                            if (!game.map[i][j].children.includes(k)) {
                                game.map[i][j].children.push(k);
                            }
                        }
                    }
                }
            }
            
            // 13层收束到 14层的 Boss
            game.map[14][2] = { id: `14-2`, type: 'boss', visited: false, children: [] };
            for (let j = 0; j < 5; j++) {
                if (game.map[13][j] !== null) {
                    game.map[13][j].children.push(2);
                }
            }

            renderMap();
        }

        function getRandomNodeType(floor) {
            if (floor === 8) return 'rest';
            const r = Math.random();
            if (r < 0.45) return 'combat';
            if (r < 0.70) return 'event';
            if (r < 0.85) return 'shop';
            return 'elite';
        }

        function hideAllViews() { ['start-view', 'combat-view', 'event-view', 'rest-view', 'shop-view', 'reward-view', 'map-view', 'player-controls'].forEach(id => { document.getElementById(id).classList.add('hidden'); }); }
        
        function updateGlobalUI() {
            document.getElementById('hp-text').innerText = `${Math.ceil(game.hp)}/${game.maxHp}`;
            document.getElementById('hp-bar').style.width = `${(game.hp / game.maxHp) * 100}%`;
            document.getElementById('gold-text').innerText = game.gold;
            document.getElementById('floor-display').innerText = `第 ${game.currentFloor + 1} 层`;
            document.getElementById('soul-val').innerText = game.soul;
            
            const relicsContainer = document.getElementById('relics'); relicsContainer.innerHTML = '';
            game.relics.forEach(r => {
                const data = RELICS_DB[r] || {name: '未知', icon: '❓', desc: '?'};
                const el = document.createElement('div'); el.className = "relic-container w-8 h-8 bg-zinc-800 rounded border border-zinc-700 flex items-center justify-center cursor-help flex-shrink-0 z-10";
                el.innerHTML = `${data.icon}<div class="relic-tooltip"><strong class="text-yellow-400 block mb-1">${data.name}</strong><span class="text-zinc-300 text-xs">${data.desc}</span></div>`;
                relicsContainer.appendChild(el);
            });
        }

        function viewMap() { 
            hideAllViews(); document.getElementById('map-view').classList.remove('hidden'); 
            document.getElementById('return-room-btn').classList.toggle('hidden', game.state === 'map'); 
            renderMap(); 
        }
        function returnToActiveRoom() { hideAllViews(); document.getElementById(`${game.state}-view`).classList.remove('hidden'); if (game.state === 'combat') document.getElementById('player-controls').classList.remove('hidden'); }
        function endRoom() { game.state = 'map'; viewMap(); updateGlobalUI(); }

        function renderMap() {
            const container = document.getElementById('map-container'); 
            container.innerHTML = '<svg id="map-lines" class="absolute inset-0 w-full h-full pointer-events-none z-0"></svg>';
            
            for (let i = 14; i >= 0; i--) {
                const rowDiv = document.createElement('div'); rowDiv.className = "map-row";
                
                for (let j = 0; j < 5; j++) {
                    const node = game.map[i][j];
                    const wrapper = document.createElement('div');
                    wrapper.className = "map-node-wrapper";

                    if (node) {
                        const el = document.createElement('div');
                        el.id = `node-${i}-${j}`;
                        
                        let isReachable = false;
                        if (game.currentFloor === -1 && i === 0) isReachable = true;
                        if (game.currentFloor !== -1 && i === game.currentFloor + 1) {
                            const parent = game.map[game.currentFloor][game.currentNodeIdx];
                            if (parent && parent.children.includes(j)) isReachable = true;
                        }
                        
                        const isCurrent = game.currentFloor === i && game.currentNodeIdx === j;
                        const interactivity = (isReachable && game.state === 'map') ? 'reachable' : '';
                        el.className = `node ${interactivity} ${isCurrent ? 'current' : ''} ${node.visited ? 'visited' : ''}`;
                        el.innerHTML = node.type === 'combat'?'⚔️':node.type === 'elite'?'👿':node.type === 'event'?'❓':node.type === 'shop'?'💰':node.type === 'rest'?'🔥':'💀';
                        if (isReachable && game.state === 'map') el.onclick = () => selectNode(i, j);
                        wrapper.appendChild(el);
                    }
                    rowDiv.appendChild(wrapper);
                }
                container.appendChild(rowDiv);
            }
            setTimeout(drawMapLines, 50); 
        }

        function drawMapLines() {
            const svg = document.getElementById('map-lines'); if(!svg) return; svg.innerHTML = '';
            const containerRect = document.getElementById('map-container').getBoundingClientRect();
            
            for(let i=0; i<14; i++){
                for(let j=0; j<5; j++) {
                    const node = game.map[i][j];
                    if(!node) continue;
                    
                    const startEl = document.getElementById(`node-${i}-${j}`); if(!startEl) continue;
                    const startRect = startEl.getBoundingClientRect();
                    const x1 = startRect.left - containerRect.left + startRect.width/2;
                    const y1 = startRect.top - containerRect.top + startRect.height/2;

                    node.children.forEach(cIdx => {
                        const endEl = document.getElementById(`node-${i+1}-${cIdx}`); if(!endEl) return;
                        const endRect = endEl.getBoundingClientRect();
                        const x2 = endRect.left - containerRect.left + endRect.width/2;
                        const y2 = endRect.top - containerRect.top + endRect.height/2;
                        
                        let isReachable = (game.currentFloor === i && game.currentNodeIdx === j);
                        let isTaken = (node.visited && game.map[i+1][cIdx].visited && game.currentFloor >= i+1); 

                        let color = '#3f3f46'; let strokeWidth = 2;
                        if (isTaken) { color = '#fbbf24'; strokeWidth = 4; } 
                        else if (isReachable) { color = '#a78bfa'; strokeWidth = 3; } 
                        
                        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                        line.setAttribute('x1', x1); line.setAttribute('y1', y1); line.setAttribute('x2', x2); line.setAttribute('y2', y2);
                        line.setAttribute('stroke', color); line.setAttribute('stroke-width', strokeWidth);
                        svg.appendChild(line);
                    });
                }
            }
        }
        window.addEventListener('resize', () => { if(game.state === 'map') drawMapLines(); });

        function selectNode(floor, idx) {
            if (game.state !== 'map') return;
            if (game.relics.includes('piggy_bank')) { game.gold += 5; spawnFloatingText('gold-text', '+5🪙', 'text-yellow-400'); }
            
            game.currentFloor = floor; game.currentNodeIdx = idx; game.map[floor][idx].visited = true;
            const node = game.map[floor][idx]; hideAllViews();
            if (['combat', 'boss', 'elite'].includes(node.type)) { game.state = 'combat'; initCombat(node.type); }
            else if (node.type === 'event') { game.state = 'event'; initEvent(); }
            else if (node.type === 'rest') { game.state = 'rest'; initRest(); }
            else if (node.type === 'shop') { game.state = 'shop'; initShop(); }
            updateGlobalUI();
        }

        // ==========================================
        // 战斗系统与 Buff 逻辑
        // ==========================================
        function getPlayerDamage(baseDmg, target) {
            let dmg = baseDmg;
            if(game.combat.playerBuffs.weak > 0) dmg = Math.floor(dmg * 0.75);
            if(target.buffs.vulnerable > 0) dmg = Math.floor(dmg * 1.5);
            return dmg;
        }

        function getEnemyDamage(baseDmg, en) {
            let dmg = baseDmg;
            if(en.buffs.weak > 0) dmg = Math.floor(dmg * 0.75);
            if(game.combat.playerBuffs.vulnerable > 0) dmg = Math.floor(dmg * 1.5);
            if(game.relics.includes('paper_crane') && en.buffs.weak > 0) dmg -= 1;
            return dmg;
        }

        function initCombat(type) {
            document.getElementById('combat-view').classList.remove('hidden'); document.getElementById('player-controls').classList.remove('hidden'); document.getElementById('battle-log').innerHTML = '';
            game.soul = 0; 
            
            let keys = Object.keys(MONSTERS_DB);
            if (type === 'boss') keys = keys.filter(k => MONSTERS_DB[k].isBoss);
            else if (type === 'elite') keys = keys.filter(k => MONSTERS_DB[k].isElite);
            else keys = keys.filter(k => !MONSTERS_DB[k].isElite && !MONSTERS_DB[k].isBoss);
            
            let enemyList = [];
            const key1 = keys[Math.floor(Math.random() * keys.length)];
            enemyList.push({ ...MONSTERS_DB[key1], hp: MONSTERS_DB[key1].hp, maxHp: MONSTERS_DB[key1].hp, currentIntentIdx: 0, id: 'enemy-0', block: 0, buffs: {weak:0, vulnerable:0} });
            if (type === 'combat' && Math.random() < 0.3) {
                const key2 = keys[Math.floor(Math.random() * keys.length)];
                enemyList.push({ ...MONSTERS_DB[key2], hp: MONSTERS_DB[key2].hp, maxHp: MONSTERS_DB[key2].hp, currentIntentIdx: 0, id: 'enemy-1', block: 0, buffs: {weak:0, vulnerable:0} });
            }

            game.combat = { 
                enemies: enemyList, draw: [...game.deck].sort(() => Math.random() - 0.5), hand: [], discard: [], 
                playerBlock: 0, playerBuffs: {weak: 0, vulnerable: 0},
                hpLossThisTurn: false, hpGainThisTurn: false, isElite: type === 'elite', isBoss: type === 'boss' 
            };
            
            if(game.relics.includes('black_crown')) game.soul += 3; else if (game.relics.includes('deep_phylactery')) game.soul += 2;
            if (game.relics.includes('iron_scales')) { spawnFloatingText('player-avatar-container', '荆棘!', 'text-green-400'); }
            
            startTurn(true);
        }

        function startTurn(isFirstTurn = false) {
            game.combat.playerBlock = 0; 
            game.energy = game.maxEnergy + (game.relics.includes('cursed_blood') ? 1 : 0);
            game.combat.hpLossThisTurn = false; game.combat.hpGainThisTurn = false;
            game.turnHpLoss = 0; 
            
            if(game.combat.playerBuffs.weak > 0) game.combat.playerBuffs.weak--;
            if(game.combat.playerBuffs.vulnerable > 0) game.combat.playerBuffs.vulnerable--;

            let drawCount = 5; if (isFirstTurn && game.relics.includes('lucky_rabbit')) drawCount += 2;
            drawCards(drawCount); renderCombat();
        }

        function drawCards(n) {
            for (let i = 0; i < n; i++) {
                if (game.combat.draw.length === 0) { game.combat.draw = [...game.combat.discard].sort(() => Math.random() - 0.5); game.combat.discard = []; }
                if (game.combat.draw.length > 0 && game.combat.hand.length < 10) game.combat.hand.push(game.combat.draw.pop());
            }
        }

        function renderCombat() {
            if(game.state !== 'combat') return;
            const enemyDiv = document.getElementById('enemies'); enemyDiv.innerHTML = '';
            game.combat.enemies.forEach((en) => {
                const intent = en.intents[en.currentIntentIdx];
                let intentIcon = ''; let intentTooltipText = '';
                
                if(intent.type === 'attack') {
                    const dmg = getEnemyDamage(intent.val, en);
                    intentIcon = `⚔️ ${dmg}${intent.times ? 'x'+intent.times : ''}`;
                    intentTooltipText = `<strong class="text-red-400">准备攻击</strong><br>这名敌人准备对你造成 ${dmg} 点伤害${intent.times ? '，共 ' + intent.times + ' 次' : ''}。`;
                } else if(intent.type === 'block') {
                    intentIcon = `🛡️ ${intent.val}`;
                    intentTooltipText = `<strong class="text-blue-400">准备防御</strong><br>这名敌人准备获得 ${intent.val} 点格挡。`;
                } else if(intent.type === 'debuff') {
                    intentIcon = `⚡`;
                    const bName = intent.buffType === 'weak' ? '虚弱(伤害降低25%)' : '易伤(受击增加50%)';
                    intentTooltipText = `<strong class="text-purple-400">准备施加负面效果</strong><br>这名敌人准备给予你 ${intent.val} 层${bName}。`;
                }

                const el = document.createElement('div'); el.id = en.id; el.className = `flex flex-col items-center gap-2 ${en.hp <= 0 ? 'hidden' : 'relative'}`;
                const enemyBlockHtml = en.block > 0 ? `<div class="absolute -right-2 top-8 bg-blue-600 text-white w-6 h-6 rounded flex items-center justify-center font-bold text-[10px] border border-white z-10 shadow-lg">${en.block}</div>` : '';
                
                let eBuffs = '';
                if(en.buffs.weak > 0) eBuffs += `<span class="bg-zinc-800 text-purple-400 border border-purple-500 rounded px-1 text-[10px]">🔽 ${en.buffs.weak}</span> `;
                if(en.buffs.vulnerable > 0) eBuffs += `<span class="bg-zinc-800 text-red-400 border border-red-500 rounded px-1 text-[10px]">💔 ${en.buffs.vulnerable}</span> `;

                el.innerHTML = `
                    <div class="relic-container mb-2 flex flex-col items-center">
                        <span class="text-xs font-bold text-red-400 bg-black/60 px-2 py-1 rounded shadow-lg cursor-help">${intentIcon}</span>
                        <div class="relic-tooltip intent-tooltip text-white z-50 text-xs">${intentTooltipText}</div>
                    </div>
                    <div class="text-6xl mb-2 filter drop-shadow-lg relative">${en.icon}${enemyBlockHtml}</div>
                    <div class="flex gap-1 mb-1 h-3">${eBuffs}</div>
                    <div class="w-32 h-3 bg-zinc-800 rounded-full border border-zinc-700 relative"><div class="h-full bg-red-600 transition-all" style="width:${(en.hp / en.maxHp) * 100}%"></div><span class="absolute inset-0 flex items-center justify-center text-[10px] text-white font-bold">${en.hp}/${en.maxHp}</span></div>
                    <span class="text-[10px] text-zinc-400 font-bold">${en.name}</span>
                `;
                enemyDiv.appendChild(el);
            });

            let pBuffs = '';
            if(game.combat.playerBuffs.weak > 0) pBuffs += `<span class="bg-zinc-800 text-purple-400 border border-purple-500 rounded px-1 text-xs font-bold shadow-lg">🔽 ${game.combat.playerBuffs.weak} 虚弱</span>`;
            if(game.combat.playerBuffs.vulnerable > 0) pBuffs += `<span class="bg-zinc-800 text-red-400 border border-red-500 rounded px-1 text-xs font-bold shadow-lg">💔 ${game.combat.playerBuffs.vulnerable} 易伤</span>`;
            document.getElementById('player-buffs-ui').innerHTML = pBuffs;

            const handDiv = document.getElementById('hand-display'); handDiv.innerHTML = '';
            game.combat.hand.forEach((cardKey, idx) => {
                const card = CARDS_DB[cardKey];
                const canAfford = game.energy >= card.cost && (!card.soulCost || game.soul >= card.soulCost);
                const html = generateCardHTML(card, canAfford ? `playCard(${idx})` : '', canAfford ? 'affordable' : 'unaffordable');
                const wrapper = document.createElement('div'); wrapper.innerHTML = html; const el = wrapper.firstElementChild;
                el.style.zIndex = idx; el.style.transform = `rotate(${(idx - game.combat.hand.length/2) * 3}deg)`;
                handDiv.appendChild(el);
            });
            document.getElementById('energy-now').innerText = game.energy; document.getElementById('draw-count').innerText = game.combat.draw.length; document.getElementById('discard-count').innerText = game.combat.discard.length; document.getElementById('player-block').innerText = game.combat.playerBlock; document.getElementById('player-block').classList.toggle('hidden', game.combat.playerBlock <= 0); updateGlobalUI();
        }

        async function playCard(idx) {
            playSound('card');
            const key = game.combat.hand[idx]; const card = CARDS_DB[key];
            game.energy -= card.cost;
            if (card.soulCost) { game.soul -= card.soulCost; if (game.relics.includes('soul_bell')) { game.combat.playerBlock += card.soulCost; spawnFloatingText('player-avatar-container', `+${card.soulCost}🛡️`, 'text-blue-400'); } }

            const targets = card.aoe ? game.combat.enemies.filter(e => e.hp > 0) : [game.combat.enemies.find(e => e.hp > 0)];
            if ((card.damage !== undefined || card.dynamicDamage) && targets[0]) {
                let times = card.times || 1;
                for(let t=0; t<times; t++) {
                    targets.forEach(target => {
                        let baseDamage = card.damage || 0;
                        if (card.executeThreshold && (target.hp / target.maxHp) <= card.executeThreshold) baseDamage = card.executeDamage;
                        if (card.bonusDmgIfSoul && game.soul > 5) baseDamage += card.bonusDmgIfSoul;
                        if (card.bonusDmgIfHpLoss && game.turnHpLoss > 0) baseDamage += card.bonusDmgIfHpLoss;
                        if (card.dynamicDamage === 'hpLoss') baseDamage = game.turnHpLoss;

                        let finalDmg = getPlayerDamage(baseDamage, target);

                        if (!card.ignoreBlock && target.block > 0) {
                            if (target.block >= finalDmg) { target.block -= finalDmg; finalDmg = 0; playSound('block'); } 
                            else { finalDmg -= target.block; target.block = 0; }
                        }
                        if (finalDmg > 0) { 
                            target.hp -= finalDmg; 
                            playSound('hit'); 
                            triggerShake(target.id); 
                            spawnSlash(target.id); 
                            spawnFloatingText(target.id, `-${finalDmg}`, 'text-red-500'); 
                        }
                        
                        if (card.applyWeak) target.buffs.weak += card.applyWeak;
                        if (card.applyVulnerable) target.buffs.vulnerable += card.applyVulnerable;

                        if (target.hp <= 0) { target.hp = 0; target.block = 0; if (card.heal) modifyHp(card.heal + (game.relics.includes('blood_idol') ? 2 : 0), true); if (card.soulOnKill) game.soul += card.soulOnKill; }
                    });
                }
            }
            if (card.block) {
                let actualBlock = card.block;
                if (card.bonusBlockSoulCost && game.soul >= card.bonusBlockSoulCost) { game.soul -= card.bonusBlockSoulCost; actualBlock += card.bonusBlock; }
                if (card.blockBySoul) actualBlock = Math.min(card.blockBySoul, game.soul);
                game.combat.playerBlock += actualBlock; playSound('block'); spawnFloatingText('player-avatar-container', `+${actualBlock}🛡️`, 'text-blue-400');
            }
            if (card.loseAllBlockDealDmg) {
                const dmg = Math.floor(game.combat.playerBlock / 5) * card.loseAllBlockDealDmg;
                game.combat.playerBlock = 0;
                if(targets[0] && dmg > 0) { targets[0].hp -= dmg; spawnSlash(targets[0].id); spawnFloatingText(targets[0].id, `-${dmg}`, 'text-red-500'); }
            }
            if (card.selfDamage) modifyHp(-card.selfDamage, true); 
            if (card.draw) drawCards(card.draw);
            if (card.drawNextTurn) { drawCards(card.drawNextTurn); }
            if (card.energyGain) { game.energy += card.energyGain; spawnFloatingText('player-avatar-container', `+${card.energyGain}🔋`, 'text-yellow-400'); }
            if (card.soulGain) { game.soul += card.soulGain; spawnFloatingText('player-avatar-container', `+${card.soulGain}✨`, 'text-violet-400'); }
            if (card.syncSoulToHand) { game.soul = game.combat.hand.length; spawnFloatingText('player-avatar-container', `共鸣!`, 'text-violet-400'); }

            game.combat.discard.push(game.combat.hand.splice(idx, 1)[0]); renderCombat(); setTimeout(checkVictory, 300);
        }

        function modifyHp(amt, isCardEffect = false) {
            game.hp += amt; if (game.hp > game.maxHp) game.hp = game.maxHp;
            if (amt < 0) {
                game.turnHpLoss += Math.abs(amt);
                playSound('hit'); triggerShake('game-app'); spawnFloatingText('player-avatar-container', amt, 'text-red-500');
                
                if (game.relics.includes('pain_amplifier') && !isCardEffect && game.state === 'combat') {
                    drawCards(1); spawnFloatingText('player-avatar-container', '抽牌!', 'text-yellow-400'); renderCombat();
                }

                let gain = 1; if (!game.combat?.hpLossThisTurn) { gain++; if(game.combat) game.combat.hpLossThisTurn = true; }
                if(game.relics.includes('black_crown') && game.combat && !game.combat.hpLossThisTurn) gain++;
                game.soul += gain; spawnFloatingText('player-avatar-container', `+${gain}✨`, 'text-violet-400');
                
                if (isCardEffect && game.relics.includes('spiked_collar')) {
                    const alive = game.combat.enemies.filter(e => e.hp > 0);
                    if (alive.length > 0) { const target = alive[Math.floor(Math.random() * alive.length)]; target.hp -= 4; spawnSlash(target.id); spawnFloatingText(target.id, "-4(项圈)", 'text-orange-400'); }
                }
            } else if (amt > 0) {
                playSound('heal'); spawnFloatingText('player-avatar-container', `+${amt}`, 'text-green-400');
                let gain = 1; if (!game.combat?.hpGainThisTurn) { gain++; if(game.combat) game.combat.hpGainThisTurn = true; }
                if(game.relics.includes('black_crown') && game.combat && !game.combat.hpGainThisTurn) gain++;
                game.soul += gain; spawnFloatingText('player-avatar-container', `+${gain}✨`, 'text-violet-400');
            }
            updateGlobalUI();
            if (game.hp <= 0) { game.hp = 0; playSound('error'); showModal("死亡", "深渊已将你彻底吞噬。<br><br><button onclick='location.reload()' class='mt-4 bg-red-900 hover:bg-red-800 px-6 py-2 rounded text-white font-bold'>重新开始</button>", false); }
        }

        function executeEndTurn() {
            playSound('card'); let delay = 0;
            if (!game.relics.includes('ice_cream')) { game.energy = 0; }
            
            game.combat.enemies.forEach(en => { en.block = 0; });
            game.combat.enemies.forEach(en => {
                if (en.hp <= 0) return;
                const intent = en.intents[en.currentIntentIdx];
                setTimeout(() => {
                    if (en.hp <= 0) return; 
                    if (intent.type === 'attack') {
                        let times = intent.times || 1;
                        for(let i=0; i<times; i++) {
                            setTimeout(() => {
                                triggerShake(en.id);
                                let dmg = getEnemyDamage(intent.val, en);
                                dmg = Math.max(0, dmg - game.combat.playerBlock);
                                if (game.combat.playerBlock > 0) { game.combat.playerBlock = Math.max(0, game.combat.playerBlock - getEnemyDamage(intent.val, en)); playSound('block'); }
                                if (dmg > 0) { modifyHp(-dmg); }
                                
                                if (game.relics.includes('iron_scales')) {
                                    en.hp -= 3; spawnSlash(en.id); spawnFloatingText(en.id, '-3(反伤)', 'text-orange-400');
                                    if(en.hp <= 0) en.hp = 0;
                                }
                                document.getElementById('player-block').innerText = game.combat.playerBlock;
                            }, i * 200);
                        }
                    } else if (intent.type === 'block') {
                        en.block += intent.val; triggerShake(en.id); spawnFloatingText(en.id, `+${intent.val}🛡️`, 'text-blue-400'); renderCombat();
                    } else if (intent.type === 'debuff') {
                        if(intent.buffType === 'weak') game.combat.playerBuffs.weak += intent.val;
                        if(intent.buffType === 'vulnerable') game.combat.playerBuffs.vulnerable += intent.val;
                        spawnFloatingText('player-avatar-container', intent.buffType==='weak'?'虚弱':'易伤', 'text-purple-400');
                    }
                    en.currentIntentIdx = (en.currentIntentIdx + 1) % en.intents.length;
                    
                    if(en.buffs.weak > 0) en.buffs.weak--;
                    if(en.buffs.vulnerable > 0) en.buffs.vulnerable--;
                }, delay);
                delay += 800; 
            });

            setTimeout(() => {
                game.combat.discard.push(...game.combat.hand); game.combat.hand = [];
                if(game.hp > 0) startTurn();
            }, delay + 200);
        }

        function checkVictory() {
            if (game.combat.enemies.every(e => e.hp <= 0)) {
                log("战斗胜利！"); game.soul = 0; 
                if (game.relics.includes('torn_bandage')) modifyHp(2); 
                updateGlobalUI(); 
                if(game.combat.isBoss) { playSound('heal'); showModal("胜利！", "你击败了本层的最终Boss。<br><button onclick='location.reload()' class='mt-4 bg-yellow-600 px-6 py-2 rounded font-bold text-white'>再来一局</button>", false); } 
                else { setTimeout(() => showRewardScreen(game.combat.isElite), 800); }
            }
        }

        function showRewardScreen(isElite) {
            game.state = 'reward'; hideAllViews(); document.getElementById('reward-view').classList.remove('hidden');
            const list = document.getElementById('reward-list'); list.innerHTML = '';
            let goldAmt = Math.floor(Math.random() * 15) + (isElite ? 25 : 10);
            if(game.relics.includes('golden_idol')) goldAmt = Math.floor(goldAmt * 1.25);
            list.innerHTML += `<button onclick="claimReward(this, () => { game.gold += ${goldAmt}; playSound('heal'); updateGlobalUI(); })" class="w-full bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 p-3 rounded text-left flex items-center gap-3"><span class="text-2xl">🪙</span> <span class="font-bold text-yellow-400">获得 ${goldAmt} 金币</span></button>`;
            if (isElite) {
                const unowned = Object.keys(RELICS_DB).filter(r => !game.relics.includes(r) && RELICS_DB[r].tier !== 'boss' && RELICS_DB[r].tier !== 'starter');
                if (unowned.length > 0) { const rId = unowned[Math.floor(Math.random() * unowned.length)]; list.innerHTML += `<button onclick="claimReward(this, () => { getRelic('${rId}'); playSound('heal'); updateGlobalUI(); })" class="w-full bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 p-3 rounded text-left flex items-center gap-3"><span class="text-2xl">${RELICS_DB[rId].icon}</span> <div><span class="font-bold text-blue-400">获得遗物：${RELICS_DB[rId].name}</span><br><span class="text-xs text-zinc-400">${RELICS_DB[rId].desc}</span></div></button>`; }
            }
            list.innerHTML += `<button onclick="draftCardReward(this)" class="w-full bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 p-3 rounded text-left flex items-center gap-3"><span class="text-2xl">🎴</span> <span class="font-bold text-green-400">将一张牌加入牌组</span></button>`;
        }

        function claimReward(btn, callback) { callback(); btn.classList.add('opacity-30', 'pointer-events-none'); btn.innerHTML += ' <span class="ml-auto text-sm text-zinc-500">(已领取)</span>'; }

        function draftCardReward(btn) {
            playSound('card');
            let pool = Object.keys(CARDS_DB).filter(k => !k.includes('+') && k !== 'strike' && k !== 'defend' && !k.startsWith('custom_'));
            pool = pool.sort(() => 0.5 - Math.random()); const choices = pool.slice(0, 3);
            let modalHtml = `<h2 class="text-2xl font-bold mb-6 text-green-400">选择一张卡牌</h2><div class="flex justify-center gap-6 mb-6">`;
            choices.forEach(key => { modalHtml += generateCardHTML(CARDS_DB[key], `addCardToDeck('${key}')`); });
            modalHtml += `</div><button onclick="closeModal()" class="bg-zinc-800 px-6 py-2 rounded text-white font-bold">跳过</button>`;
            showModal("", modalHtml, false);
            btn.classList.add('opacity-30', 'pointer-events-none'); btn.innerHTML += ' <span class="ml-auto text-sm text-zinc-500">(已领取)</span>'; btn.onclick = null;
        }

        function addCardToDeck(cardKey) { playSound('heal'); game.deck.push(cardKey); closeModal(); updateGlobalUI(); }

        function getRelic(rId) { game.relics.push(rId); if (rId === 'roasted_apple') { game.maxHp += 7; modifyHp(7); } }

        // --- 商店逻辑 ---
        function initShop() {
            document.getElementById('shop-view').classList.remove('hidden'); const shopCards = document.getElementById('shop-cards'); shopCards.innerHTML = '';
            let cardPool = Object.keys(CARDS_DB).filter(k => !k.includes('+') && k !== 'strike' && k !== 'defend' && !k.startsWith('custom_')).sort(() => 0.5 - Math.random());
            cardPool.slice(0, 4).forEach(cKey => { 
                const price = Math.floor(Math.random() * 20) + 40;
                const el = document.createElement('div'); el.className = "flex flex-col items-center gap-2";
                el.innerHTML = `${generateCardHTML(CARDS_DB[cKey], '', '', 'width:110px; height:150px;')}<button class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 px-4 py-1 rounded text-sm text-yellow-400 font-bold flex items-center gap-1"><span class="text-xs">🪙</span> ${price}</button>`;
                el.querySelector('button').onclick = (e) => { if (game.gold >= price) { playSound('heal'); game.gold -= price; game.deck.push(cKey); updateGlobalUI(); el.style.opacity = 0.3; el.querySelector('button').disabled = true; el.querySelector('button').innerText = '已售出'; } else { playSound('error'); } };
                shopCards.appendChild(el);
            });
            const unowned = Object.keys(RELICS_DB).filter(r => !game.relics.includes(r) && RELICS_DB[r].tier !== 'boss' && RELICS_DB[r].tier !== 'starter');
            const shopRelics = document.getElementById('shop-relics'); shopRelics.innerHTML = '';
            unowned.sort(() => 0.5 - Math.random()).slice(0, 2).forEach(rKey => {
                const relic = RELICS_DB[rKey]; const el = document.createElement('div'); el.className = "relic-container flex flex-col items-center gap-2 w-32 cursor-help z-10";
                el.innerHTML = `<div class="w-16 h-16 bg-zinc-800 rounded border-2 border-zinc-600 flex items-center justify-center text-3xl">${relic.icon}</div><div class="relic-tooltip"><strong class="text-yellow-400 block mb-1">${relic.name}</strong><span class="text-zinc-300 text-xs">${relic.desc}</span></div><div class="text-xs font-bold text-center h-8">${relic.name}</div><button class="bg-zinc-800 hover:bg-zinc-700 border border-zinc-600 w-full py-1 rounded text-sm text-yellow-400 font-bold flex justify-center items-center gap-1"><span class="text-xs">🪙</span> 150</button>`;
                el.querySelector('button').onclick = (e) => { if (game.gold >= 150) { playSound('heal'); game.gold -= 150; getRelic(rKey); updateGlobalUI(); el.style.opacity = 0.3; el.querySelector('button').disabled = true; el.querySelector('button').innerText = '已售出'; } else { playSound('error'); } };
                shopRelics.appendChild(el);
            });
            let removeCostFinal = game.relics.includes('lucky_coin') ? Math.max(25, game.removeCost - 25) : game.removeCost;
            document.getElementById('remove-price').innerText = `${removeCostFinal} 金币`;
        }

        function buyRemoval() {
            let removeCostFinal = game.relics.includes('lucky_coin') ? Math.max(25, game.removeCost - 25) : game.removeCost;
            if (game.gold >= removeCostFinal && game.deck.length > 0) {
                playSound('card'); let modalHtml = `<h2 class="text-2xl font-bold mb-4 text-red-400">选择要移除的卡牌</h2><div class="flex flex-wrap justify-center gap-4 max-h-96 overflow-y-auto p-2">`;
                game.deck.forEach((key, idx) => { const card = CARDS_DB[key]; modalHtml += `<div onclick="playSound('hit'); game.gold -= ${removeCostFinal}; game.removeCost += 25; game.deck.splice(${idx}, 1); closeModal(); updateGlobalUI();" class="card card-grid-item p-2 text-xs border border-zinc-600 cursor-pointer"><div class="font-bold mb-1 text-white">${card.name}</div><div class="text-zinc-500">${card.type==='attack'?'攻击':'技能'}</div></div>`; });
                modalHtml += `</div>`; showModal("", modalHtml, true);
            } else { playSound('error'); }
        }

        // --- 休息处与 Gemini API ✨ 深渊铸造 ✨ ---
        const geminiApiKey = apiKey; // 使用注入的 API Key

        function initRest() { 
            document.getElementById('rest-view').classList.remove('hidden'); 
            document.getElementById('rest-menu').classList.remove('hidden'); 
            document.getElementById('smith-menu').classList.add('hidden'); 
            document.getElementById('forge-menu').classList.add('hidden'); 
        }

        function handleRest(type) { 
            if (type === 'heal') { 
                if(game.relics.includes('cursed_blood')) { playSound('error'); spawnFloatingText('player-avatar-container', '诅咒之血!', 'text-red-500'); return; }
                playSound('heal'); modifyHp(Math.floor(game.maxHp * 0.3)); setTimeout(endRoom, 500); 
            } 
            else if (type === 'smith') { 
                document.getElementById('rest-menu').classList.add('hidden'); document.getElementById('smith-menu').classList.remove('hidden'); 
                const container = document.getElementById('smith-cards'); container.innerHTML = '';
                game.deck.forEach((key, idx) => {
                    const isUpgradable = !key.includes('+') && CARDS_DB[key + '+'];
                    const wrapper = document.createElement('div'); wrapper.innerHTML = generateCardHTML(CARDS_DB[key], '', isUpgradable ? 'border-blue-500 cursor-pointer' : 'border-zinc-700 opacity-50 cursor-not-allowed');
                    const el = wrapper.firstElementChild;
                    if (isUpgradable) { el.onclick = () => { playSound('card'); showModal("", `<h2 class="text-3xl font-bold mb-8 text-blue-400">卡牌锻造</h2><div class="flex justify-center items-center gap-12 mb-8"><div class="flex flex-col items-center"><span class="text-zinc-400 mb-2 font-bold">升级前</span>${generateCardHTML(CARDS_DB[key], '', 'preview-card')}</div><span class="text-5xl text-blue-500">➡️</span><div class="flex flex-col items-center"><span class="text-green-400 mb-2 font-bold">升级后</span>${generateCardHTML(CARDS_DB[key+'+'], '', 'preview-card border-green-500')}</div></div><button onclick="playSound('block'); game.deck[${idx}] = '${key+'+'}'; closeModal(); setTimeout(endRoom, 400);" class="bg-blue-700 hover:bg-blue-600 px-10 py-3 rounded text-white font-bold text-lg">确认锻造</button>`, true); }; }
                    container.appendChild(el);
                });
            }
            else if (type === 'forge') {
                document.getElementById('rest-menu').classList.add('hidden'); 
                document.getElementById('forge-menu').classList.remove('hidden');
                document.getElementById('forge-input').value = '';
            }
        }
        function cancelRestSubmenu() { 
            document.getElementById('smith-menu').classList.add('hidden'); 
            document.getElementById('forge-menu').classList.add('hidden'); 
            document.getElementById('rest-menu').classList.remove('hidden'); 
        }

        async function executeForge() {
            const input = document.getElementById('forge-input').value.trim() || '暗黑骑士的神秘专属力量';
            document.getElementById('forge-btn').disabled = true;
            document.getElementById('forge-btn').classList.add('opacity-50', 'cursor-not-allowed');
            document.getElementById('forge-status').classList.remove('hidden');
            playSound('card');

            const systemInstruction = `你是一个《杀戮尖塔》风格的暗黑骑士卡牌设计师。
请根据玩家提供的主题设计一张暗黑风格、逻辑合理、数值平衡的卡牌。
必须返回严格的JSON对象，不包含任何外部格式或Markdown。
JSON包含以下字段（必须包含前4个）：
"name": 字符串 (卡牌名字)
"cost": 整数 (费用 0-3)
"type": 字符串 (必须是 "attack" 或 "skill")
"desc": 字符串 (效果描述文字，如"造成15伤害。失去2生命。")
可选字段（如果没有此效果则不要输出或者写0）：
"damage": 整数 (攻击伤害)
"block": 整数 (获得格挡)
"heal": 整数 (回血)
"selfDamage": 整数 (失去生命/自残)
"soulCost": 整数 (消耗灵魂)
"soulGain": 整数 (获得灵魂)
"draw": 整数 (抽牌数量)
"energyGain": 整数 (获得能量)`;

            const payload = {
                contents: [{ parts: [{ text: `玩家的主题渴望是：${input}` }] }],
                systemInstruction: { parts: [{ text: systemInstruction }] },
                generationConfig: { responseMimeType: "application/json" }
            };

            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${geminiApiKey}`;
            
            let delay = 1000;
            let success = false;
            let cardData = null;

            for (let i = 0; i < 5; i++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (!response.ok) throw new Error('API Request Failed');
                    const data = await response.json();
                    const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
                    if(text) {
                        cardData = JSON.parse(text);
                        success = true;
                        break;
                    } else {
                         throw new Error('Invalid Response Format');
                    }
                } catch (err) {
                    if (i === 4) break;
                    await new Promise(r => setTimeout(r, delay));
                    delay *= 2;
                }
            }

            document.getElementById('forge-btn').disabled = false;
            document.getElementById('forge-btn').classList.remove('opacity-50', 'cursor-not-allowed');
            document.getElementById('forge-status').classList.add('hidden');

            if (success && cardData) {
                const newCard = {
                    name: cardData.name || '深渊造物',
                    cost: cardData.cost || 0,
                    type: cardData.type === 'attack' ? 'attack' : 'skill',
                    desc: cardData.desc || '来自深渊的神秘卡牌。'
                };
                ["damage", "block", "heal", "selfDamage", "soulCost", "soulGain", "draw", "energyGain"].forEach(key => {
                    if (cardData[key]) newCard[key] = parseInt(cardData[key]);
                });

                const upCard = { ...newCard, name: newCard.name + '+' };
                if (upCard.damage) upCard.damage += Math.ceil(upCard.damage * 0.3);
                if (upCard.block) upCard.block += Math.ceil(upCard.block * 0.3);

                const cKey = 'custom_' + Date.now();
                CARDS_DB[cKey] = newCard; CARDS_DB[cKey + '+'] = upCard;
                
                playSound('heal'); game.deck.push(cKey);
                showModal("✨ 铸造成功", `<div class="text-zinc-300 mb-6 text-center">深渊回应了你的祈求，赐予了你全新的力量...</div><div class="flex justify-center">${generateCardHTML(newCard)}</div><button onclick="closeModal(); endRoom();" class="mt-6 bg-violet-800 hover:bg-violet-700 px-6 py-2 rounded text-white font-bold w-full shadow-lg">收下并继续</button>`);
            } else {
                playSound('error');
                showModal("铸造失败", `<div class="text-red-400 mb-6 text-center">深渊拒绝了沟通，你的意念消散在了虚空之中。请稍后再试。</div><button onclick="closeModal()" class="mt-6 bg-zinc-800 hover:bg-zinc-700 px-6 py-2 rounded text-white font-bold w-full">返回</button>`);
            }
        }

        function initEvent() {
            document.getElementById('event-view').classList.remove('hidden');
            const ev = EVENTS_POOL[Math.floor(Math.random() * EVENTS_POOL.length)];
            document.getElementById('event-title').innerText = ev.title; document.getElementById('event-desc').innerText = ev.desc;
            const container = document.getElementById('event-options'); container.innerHTML = '';
            ev.opts.forEach(o => { const b = document.createElement('button'); b.className = "event-btn"; b.innerHTML = `<span>🔸</span> ${o.t}`; b.onclick = o.f; container.appendChild(b); });
        }

        function log(msg) { const l = document.getElementById('battle-log'); const d = document.createElement('div'); d.innerText = `> ${msg}`; l.prepend(d); if (l.children.length > 5) l.removeChild(l.lastChild); }
        function showModal(title, contentHtml, showCloseBtn = false) { document.getElementById('modal').classList.remove('hidden'); const contentDiv = document.getElementById('modal-content'); contentDiv.innerHTML = contentHtml; if(title) contentDiv.innerHTML = `<h2 class="text-2xl font-bold mb-4">${title}</h2>` + contentDiv.innerHTML; document.getElementById('modal-close-btn').classList.toggle('hidden', !showCloseBtn); }
        function closeModal() { document.getElementById('modal').classList.add('hidden'); }

    </script>
</body>
</html>
