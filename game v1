            floater.innerText = text; floater.className = `floating-text text-3xl ${colorClass}`;
            const offsetX = (Math.random() - 0.5) * 40;
            floater.style.left = (rect.left + rect.width / 2 + offsetX) + 'px'; floater.style.top = (rect.top + rect.height / 2) + 'px';
            document.body.appendChild(floater); setTimeout(() => floater.remove(), 800);
        }
